{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://polarisor.local/polarpilot/polarpilot-events.schema.json",
  "definitions": {
    "PilotEvent": {
      "type": "object",
      "required": ["ts", "type", "source_project", "severity", "dedup_key", "payload"],
      "properties": {
        "ts": { "type": "string" },
        "type": {
          "type": "string",
          "enum": [
            "bug",
            "digist_report",
            "contract_red",
            "git_push_main",
            "scheduled_health_scan",
            "build_failure",
            "api_5xx",
            "cli_nonzero_exit",
            "custom"
          ]
        },
        "source_project": { "type": "string" },
        "target_project": { "type": "string" },
        "severity": { "type": "string", "enum": ["info", "warning", "error", "critical"] },
        "dedup_key": { "type": "string" },
        "payload": { "type": "object" }
      },
      "additionalProperties": false
    },
    "EmitEventResponse": {
      "type": "object",
      "required": ["accepted", "event_id", "dedup_skipped"],
      "properties": {
        "accepted": { "type": "boolean" },
        "event_id": { "type": "string" },
        "dedup_skipped": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "examples": {
    "emit_response": {
      "accepted": true,
      "event_id": "evt-abc123",
      "dedup_skipped": false
    }
  }
}
