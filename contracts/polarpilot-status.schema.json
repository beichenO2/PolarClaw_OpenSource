{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://polarisor.local/polarpilot/polarpilot-status.schema.json",
  "definitions": {
    "PilotStatusResponse": {
      "type": "object",
      "required": ["project_id", "state", "active_targets", "completed_targets", "pending_events"],
      "properties": {
        "project_id": { "type": "string" },
        "state": { "type": "string", "enum": ["dormant", "active", "error", "unknown"] },
        "current_node": { "type": "string" },
        "last_active_at": { "type": "string" },
        "active_targets": { "type": "integer", "minimum": 0 },
        "completed_targets": { "type": "integer", "minimum": 0 },
        "pending_events": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "PilotHealthResponse": {
      "type": "object",
      "required": ["healthy", "uptime_ms", "projects_monitored"],
      "properties": {
        "healthy": { "type": "boolean" },
        "uptime_ms": { "type": "integer", "minimum": 0 },
        "projects_monitored": { "type": "integer", "minimum": 0 },
        "last_scan_at": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "examples": {
    "status_response": {
      "project_id": "knowlever",
      "state": "active",
      "current_node": "compile-pipeline",
      "last_active_at": "2026-05-03T01:00:00Z",
      "active_targets": 3,
      "completed_targets": 12,
      "pending_events": 1
    },
    "health_response": {
      "healthy": true,
      "uptime_ms": 3600000,
      "projects_monitored": 5,
      "last_scan_at": "2026-05-03T01:00:00Z"
    }
  }
}
